<odoo>
    <data>
        <record id="clinic_view_tree" model="ir.ui.view">
            <field name="name">clinic.tree</field>
        <field name="model">clinic</field>
        <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="address"/>
                </tree>
        </field>

        </record>
        <record id="clinic_view_form" model="ir.ui.view">
            <field name="name">clinic.form</field>
        <field name="model">clinic</field>
        <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="address"/>
                            <field name="doctor_ids" widget="many2many_tags"/>

                        </group>
                    </sheet>
                </form>
        </field>
        </record>
    </data>
    <record id="clinic_action" model="ir.actions.act_window">
        <field name="name">Clinic</field>
        <field name="res_model">clinic</field>
    </record>

    <menuitem
            id="clinic_item"
            name="Clinic"
            parent="clinic_menu"
            action="clinic_action"
    />
</odoo>