<odoo>
    <record id="monthly_report" model="ir.actions.report">
    <field name="name">Expenses Report</field>
    <field name="model">expense</field>
    <field name="report_type">qweb-pdf</field>

    <field name="report_name">expense_tracker.expenses_report_template</field>
    <field name="report_file">expense_tracker.expenses_report_template</field>

    <field name="binding_model_id" ref="model_expense"/>
    <field name="binding_type">report</field>
</record>

    <template id="expenses_report_template">
    <t t-call="web.html_container">
        <t t-call="web.external_layout">

            <div class="page">
                <h2 style="text-align:center;">
                    Expenses Report
                </h2>

                <table class="table table-sm table-bordered">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>User</th>
                            <th>Amount</th>
                            <th>Date</th>
                            <th>Type</th>
                        </tr>
                    </thead>

                    <tbody>
                        <t t-foreach="docs" t-as="o">
                            <tr>
                                <td>
                                    <span t-field="o.name"/>
                                </td>

                                <td>
                                    <span t-field="o.user_id"/>
                                </td>

                                <td>
                                    <span t-field="o.amount"/>
                                </td>

                                <td>
                                    <span t-field="o.date"/>
                                </td>

                                <td>
                                    <span t-field="o.type"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <div style="margin-top:20px;">
                    <strong>Total Expenses:</strong>

                    <span t-esc="
                        sum(
                            docs.mapped('amount')
                        )
                    "/>
                </div>

            </div>

        </t>
    </t>
</template>
</odoo>